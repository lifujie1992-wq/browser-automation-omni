# Browser Automation Omni - Environment Variables
# Copy this file to .env and adjust paths for your system.

# Required: Point to the browser-automation-omni repo root
export BROWSER_OMNI_RUNTIME="$HOME/browser-automation-omni"

# Tools directory (where CloakBrowser and other tools are cloned)
export TOOLS_DIR="$HOME/github-tools"

# CloakBrowser (optional, needed for launch_profile.py / profile_lock.py)
export CLOAKBROWSER_REPO="$TOOLS_DIR/CloakBrowser"
export CLOAKBROWSER_PY="$CLOAKBROWSER_REPO/.venv/bin/python"
export CLOAKBROWSER_HOME="$HOME/.cloakbrowser"
export CLOAKBROWSER_PROFILE_DIR="$CLOAKBROWSER_HOME/profiles"

# browser-use workspace (optional)
export BROWSER_USE_WORKSPACE="$HOME/browser-use-workspace"

# --- Windows Users ---
# On Windows (git-bash/MSYS2), the venv python path is different:
# export CLOAKBROWSER_PY="$CLOAKBROWSER_REPO/.venv/Scripts/python"
# Or use absolute paths:
# export CLOAKBROWSER_PY="C:/Users/YourUser/github-tools/CloakBrowser/.venv/Scripts/python.exe"
